# WhatsApp Bridge Configuration
# ==============================

# Port for the Go bridge REST API
WHATSAPP_BRIDGE_PORT=8080

# Webhook URL for incoming messages (optional)
# Set this to forward incoming WhatsApp messages to another service. Once set,
# the bridge authenticates every outbound webhook POST with the same bridge
# token it uses for inbound REST auth, sent as an
# "X-Bridge-Token: <WHATSAPP_BRIDGE_TOKEN>" header. A dedicated header is used
# instead of Authorization so it never collides with a receiver's own
# Authorization-based auth (e.g. HTTP Basic auth embedded in this URL as
# http://user:pass@host/...). The token is ONLY sent when this variable is
# explicitly set — never to the built-in localhost default — since the same
# token also authorizes /api/* calls like sending messages, and nothing has
# vetted whatever process might be listening on an unconfigured default.
# Redirects are never followed, so a misconfigured or malicious endpoint can't
# redirect the token to a different host.
WEBHOOK_URL=http://localhost:8769/whatsapp/webhook

# Forward messages sent by self (true/false, default true)
FORWARD_SELF=false

# Bearer token used to authenticate REST callers AND signed onto every outbound
# webhook POST (see WEBHOOK_URL above). The bridge generates one automatically
# at first start and writes it to .bridge-token in the bridge store directory
# (mode 0600). The MCP server falls back to .bridge-token next to
# WHATSMEOW_DB_PATH. Override here to inject a token from the outside (e.g.
# from a secret store in a container) instead of mounting the file.
# WHATSAPP_BRIDGE_TOKEN=

# Allow the QR pairing flow when no session is stored. Default false.
# Pairing only works with someone present to scan the code, so an unattended
# process that pairs on demand ends up requesting registration codes in a loop
# after any logout. Set true only for the interactive first pair.
# WHATSAPP_ALLOW_PAIRING=false

# Name this bridge registers as a linked device. Shows under Linked Devices on
# the phone and is sent in the pairing handshake; whatsmeow's default is the
# library's own name. Defaults to the machine's hostname. Only read at pair
# time — changing it does not affect an already-paired session.
# WHATSAPP_DEVICE_NAME=

# Cold-send limits. A "cold" send opens a conversation with someone who has
# never messaged this account; replies into existing chats are never metered.
# Over either limit, /api/send returns 429 with retry_after_seconds.
# Minimum seconds between two cold sends (default 30):
# WHATSAPP_COLD_MIN_INTERVAL_SEC=30
# Maximum new conversations per calendar day (default 50; 0 disables cold
# sends entirely):
# WHATSAPP_COLD_DAILY_CAP=50

# Colon-separated absolute paths that /api/send may read media files from.
# Default: ~/.local/share/whatsapp-mcp/outbox (created on first use). Files
# outside the listed roots are rejected with 403, defending against arbitrary-
# file-read abuse via media_path.
# WHATSAPP_MEDIA_ROOTS=/Users/yourname/.local/share/whatsapp-mcp/outbox:/Users/yourname/Pictures/wa-outbox


# MCP Server Configuration
# ========================

# Path to the SQLite messages database
# Default: <repo>/bridge/store/messages.db
# WHATSAPP_DB_PATH=./bridge/store/messages.db

# Path to whatsmeow's SQLite database (used to resolve LIDs <-> phone numbers)
# Default: <repo>/bridge/store/whatsapp.db
# WHATSMEOW_DB_PATH=./bridge/store/whatsapp.db

# Go bridge REST API URL
WHATSAPP_API_URL=http://localhost:8080/api

# ============================================================================
# MCP transport + auth (only needed to expose the server remotely to claude.ai)
# ============================================================================
# Transport: "stdio" (local / Claude Code, the default) or "http" (remote).
MCP_TRANSPORT=stdio
MCP_HOST=0.0.0.0
MCP_PORT=8000

# --- Auth (http transport only) -------------------------------------------
# Choose ONE mode. Leave MCP_OAUTH_PROVIDER empty to use the static bearer
# (MCP_BEARER_TOKEN) for Claude Code, or authless local dev.
#
#   authkit  (recommended for claude.ai web) -- stateless WorkOS AuthKit:
#            set MCP_OAUTH_PROVIDER=authkit + WORKOS_AUTHKIT_DOMAIN + MCP_BASE_URL.
#   workos   -- WorkOS OAuth proxy: + WORKOS_CLIENT_ID + WORKOS_CLIENT_SECRET,
#            and register <MCP_BASE_URL>/auth/callback in the WorkOS app.
#   oidc     -- any OIDC provider: MCP_OIDC_CONFIG_URL + MCP_OIDC_CLIENT_ID (+secret).
MCP_OAUTH_PROVIDER=

# Public https base of THIS server, WITHOUT the /mcp suffix (what OAuth
# metadata advertises; equals the claude.ai connector URL minus /mcp).
MCP_BASE_URL=

# Static bearer accepted on /mcp (the Claude Code path); works alongside OAuth.
MCP_BEARER_TOKEN=

# Refuse to start authless over http unless this is explicitly true.
MCP_ALLOW_UNAUTHENTICATED=false

# authkit / workos mode: the AuthKit tenant domain.
WORKOS_AUTHKIT_DOMAIN=
# workos mode only:
WORKOS_CLIENT_ID=
WORKOS_CLIENT_SECRET=
# oidc mode only:
MCP_OIDC_CONFIG_URL=
MCP_OIDC_CLIENT_ID=
MCP_OIDC_CLIENT_SECRET=
